# ===== PRODUCTION backend env (Render) =====
# Set these in your host's dashboard (never commit real values).

APP_ENV=production

# --- AI: your OpenAI key ---
OPENAI_API_KEY=sk-...           # used for gpt-4o-mini scoring AND Whisper transcription
TRANSCRIPTION_PROVIDER=openai   # cloud Whisper; do NOT use 'local' in the cloud
# (Leave LLM_BASE_URL unset to use OpenAI. To cut costs point scoring at Groq instead:
#  LLM_BASE_URL=https://api.groq.com/openai/v1, LLM_API_KEY=gsk_...,
#  LLM_MODEL=llama-3.3-70b-versatile — keep OPENAI_API_KEY set for Whisper.)

# --- Database: managed Postgres connection string ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Auth: MUST be strong in production (>=32 chars) ---
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace-with-a-32+char-random-secret
FREE_CREDITS_ON_SIGNUP=3

# --- Payments: Paddle (Merchant of Record, works in Kosovo) ---
PAYMENT_PROVIDER=paddle
PADDLE_API_KEY=...                   # Paddle dashboard → Developer → Authentication
PADDLE_WEBHOOK_SECRET=...            # Paddle dashboard → Developer → Notifications → signing secret
# One Paddle *price id* per subscription plan (recurring prices, created in Paddle dashboard):
PADDLE_PRICE_CREATOR=pri_...         # Creator €14/mo, 150 credits/mo
PADDLE_PRICE_PRO=pri_...             # Pro €29/mo, 500 credits/mo
PADDLE_PRICE_AGENCY=pri_...          # Agency €79/mo, 2000 credits/mo
# One price id per one-time credit pack:
PADDLE_PRICE_PACK_SMALL=pri_...      # 50 credits / €9
PADDLE_PRICE_PACK_LARGE=pri_...      # 200 credits / €29
# Set to true only for testing with a Paddle sandbox account:
# PADDLE_SANDBOX=true

# --- URLs / CORS (your deployed frontend) ---
FRONTEND_URL=https://hyperyzer.com
# Optional: extra allowed origins, comma-separated
# CORS_ORIGINS=https://hyperyzer.com,https://www.hyperyzer.com

# --- Uploads / limits ---
MAX_UPLOAD_MB=200
MAX_ACTIVE_VIDEO_JOBS=5
